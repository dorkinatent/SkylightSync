# iCloud Album Configuration
ICLOUD_ALBUM_URL=https://www.icloud.com/sharedalbum/your-album-id
RECIPIENT_EMAIL=your-skylight-frame@ourskylight.com

# Email Provider (smtp or sendgrid)
EMAIL_PROVIDER=smtp

# SMTP Configuration (Gmail example)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-specific-password

# SendGrid Configuration (alternative to SMTP)
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=your-sendgrid-api-key
# SENDER_EMAIL=noreply@yourdomain.com

# For Gmail:
# 1. Enable 2-factor authentication
# 2. Generate app password at https://myaccount.google.com/apppasswords
# 3. Use the 16-character password above

# For other providers, see email_setup_guide.md
